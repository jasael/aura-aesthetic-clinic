---
---

<section id="inicio" class="relative min-h-screen pt-28 pb-16 flex items-center overflow-hidden bg-brand-champagne-light/30">
  <!-- Background Decorative Fluid Curves (CSS Shapes) -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <!-- Curved divider at the bottom of hero -->
    <div class="absolute bottom-0 left-0 w-full h-32 bg-brand-bg clip-curve-bottom"></div>
    
    <!-- Organic glowing blobs representing aesthetic harmony -->
    <div class="absolute -top-[15%] right-[5%] w-[50%] h-[60%] bg-brand-sage-light/60 clip-leaf-right blur-3xl animate-pulse-soft"></div>
    <div class="absolute top-[40%] -left-[10%] w-[35%] h-[45%] bg-brand-champagne/15 clip-leaf-left blur-2xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
    
    <!-- Hero Copy Content (Left Column) -->
    <div class="lg:col-span-6 flex flex-col items-start text-left space-y-8 animate-fade-up">
      <!-- Muted Badge Accent -->
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-brand-sage/10 border border-brand-sage/20 shadow-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-sage animate-ping"></span>
        <span class="font-sans text-xs tracking-widest font-semibold uppercase text-brand-sage-dark">Clínica de Medicina Estética</span>
      </div>

      <!-- Main Heading with GDE typography layout -->
      <div class="space-y-4">
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-light tracking-tight leading-[1.08] text-brand-dark">
          Tu belleza natural,<br />
          <span class="font-medium italic text-brand-sage-dark relative">
            realzada con arte
            <!-- Underline custom SVG wave -->
            <svg class="absolute bottom-0 left-0 w-full h-2.5 text-brand-champagne/50" viewBox="0 0 100 10" preserveAspectRatio="none">
              <path d="M0,5 Q25,0 50,5 T100,5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
            </svg>
          </span>
        </h1>
        <p class="max-w-xl font-sans text-base md:text-lg text-brand-dark-soft font-light leading-relaxed">
          En <strong class="font-semibold text-brand-dark">Aura</strong> combinamos ciencia médica de vanguardia con un enfoque minimalista para esculpir y rejuvenecer tu piel, logrando resultados armoniosos y sutiles.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a href="#contacto" class="inline-flex items-center justify-center px-8 py-4 bg-brand-sage hover:bg-brand-sage-dark text-brand-bg font-display text-xs tracking-widest uppercase font-medium rounded-sm transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5 group">
          Agendar Consulta
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
        <a href="#servicios" class="inline-flex items-center justify-center px-8 py-4 bg-transparent border border-brand-sage/40 hover:border-brand-sage text-brand-dark-soft hover:text-brand-dark font-display text-xs tracking-widest uppercase font-medium rounded-sm transition-all duration-300 backdrop-blur-sm hover:bg-white/10">
          Explorar Servicios
        </a>
      </div>

      <!-- Floating Stat Overlays (Micro-Interactions) -->
      <div class="grid grid-cols-3 gap-6 pt-6 border-t border-brand-sage/15 w-full">
        <div>
          <span class="block font-display text-3xl font-light text-brand-sage-dark">10+</span>
          <span class="block font-sans text-[11px] tracking-wider uppercase text-brand-dark-soft/70 mt-1">Años de Arte</span>
        </div>
        <div>
          <span class="block font-display text-3xl font-light text-brand-sage-dark">5k+</span>
          <span class="block font-sans text-[11px] tracking-wider uppercase text-brand-dark-soft/70 mt-1">Rostros Felices</span>
        </div>
        <div>
          <span class="block font-display text-3xl font-light text-brand-sage-dark">99%</span>
          <span class="block font-sans text-[11px] tracking-wider uppercase text-brand-dark-soft/70 mt-1">Satisfechos</span>
        </div>
      </div>
    </div>

    <!-- Hero Image Collage Area (Right Column) -->
    <div class="lg:col-span-6 relative flex justify-center lg:justify-end animate-fade-right">
      <!-- Geometric Organic Background Overlays -->
      <div class="absolute top-[10%] -left-[5%] w-[110%] h-[80%] bg-brand-champagne/15 clip-leaf-right -rotate-6 blur-md pointer-events-none"></div>
      
      <!-- Primary Visual Frame -->
      <div class="relative w-full max-w-[480px] aspect-[4/5] rounded-[2rem] overflow-hidden shadow-2xl border-4 border-white/65 transform hover:scale-[1.01] transition-transform duration-500 clip-leaf-right">
        <img 
          src="/images/hero_aesthetic.png" 
          alt="Clínica de Medicina Estética Aura" 
          class="w-full h-full object-cover animate-pulse-soft"
          loading="eager"
        />
        
        <!-- Floating Glassmorphic Mini-Badge overlay -->
        <div class="absolute bottom-6 left-6 right-6 p-5 glass-luxe-light rounded-2xl shadow-xl flex items-center justify-between border border-white/30 backdrop-blur-md">
          <div class="space-y-1">
            <span class="block font-display text-base font-semibold text-brand-dark">Aura Recoleta</span>
            <span class="block font-sans text-xs text-brand-dark-soft/90">Av. del Libertador 1500, Buenos Aires</span>
          </div>
          <span class="flex h-3.5 w-3.5 relative">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-sage opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-brand-sage"></span>
          </span>
        </div>
      </div>
    </div>

  </div>
</section>
