---
---

<section id="contacto" class="relative py-24 md:py-32 bg-brand-champagne-light/10 overflow-hidden">
  <!-- Subtle organic background curves -->
  <div class="absolute inset-0 pointer-events-none opacity-20">
    <div class="absolute top-10 -left-10 w-96 h-96 bg-brand-sage-light clip-leaf-right blur-3xl"></div>
    <div class="absolute bottom-10 -right-10 w-96 h-96 bg-brand-champagne-light clip-leaf-left blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-12 items-start">
      
      <!-- Interactive Booking Form (Left Column, col-span-7) -->
      <div class="lg:col-span-7 bg-white p-8 md:p-12 rounded-3xl border border-brand-sage/10 shadow-lg relative">
        <div class="space-y-4 mb-8">
          <span class="font-sans text-xs tracking-[0.2em] uppercase font-semibold text-brand-sage-dark">Reservá Tu Turno</span>
          <h2 class="font-display text-2xl md:text-3xl font-light tracking-tight text-brand-dark">
            Agendá tu consulta de <span class="font-medium italic text-brand-sage-dark">diagnóstico sin cargo</span>
          </h2>
          <p class="font-sans text-xs md:text-sm text-brand-dark-soft/90 font-light">
            Completá tus datos y nuestro equipo médico se contactará en minutos para confirmar el día y horario que mejor te convenga.
          </p>
        </div>

        <!-- Success Message Overlay -->
        <div id="booking-success" class="absolute inset-0 bg-white/98 rounded-3xl z-20 flex flex-col items-center justify-center text-center p-8 hidden animate-fade-in">
          <div class="w-16 h-16 rounded-full bg-brand-sage/10 border border-brand-sage/35 flex items-center justify-center text-brand-sage-dark mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          </div>
          <h3 class="font-display text-2xl font-light text-brand-dark mb-2">¡Tu consulta ha sido reservada!</h3>
          <p class="font-sans text-sm text-brand-dark-soft/90 max-w-sm leading-relaxed mb-6">
            Hemos recibido tus datos con éxito. En breve, una de nuestras asesoras te enviará la confirmación oficial a tu celular.
          </p>
          <button id="reset-form" class="px-6 py-2.5 bg-brand-sage hover:bg-brand-sage-dark text-brand-bg font-display text-xs tracking-widest uppercase font-medium rounded-sm transition-colors duration-300">
            Volver a reservar
          </button>
        </div>

        <form id="booking-form" class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Full Name -->
            <div class="space-y-2">
              <label for="name" class="block font-sans text-xs uppercase tracking-wider text-brand-dark font-semibold">Nombre Completo</label>
              <input 
                type="text" 
                id="name" 
                required 
                placeholder="Ej. Sofía Ramos" 
                class="w-full px-4 py-3 bg-brand-bg border border-brand-sage/15 rounded-lg font-sans text-sm text-brand-dark placeholder-brand-dark-soft/40 focus:outline-none focus:border-brand-sage transition-colors duration-300"
              />
            </div>
            
            <!-- Phone Number -->
            <div class="space-y-2">
              <label for="phone" class="block font-sans text-xs uppercase tracking-wider text-brand-dark font-semibold">Teléfono Celular</label>
              <input 
                type="tel" 
                id="phone" 
                required 
                placeholder="Ej. 11 1234 5678" 
                class="w-full px-4 py-3 bg-brand-bg border border-brand-sage/15 rounded-lg font-sans text-sm text-brand-dark placeholder-brand-dark-soft/40 focus:outline-none focus:border-brand-sage transition-colors duration-300"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Email -->
            <div class="space-y-2">
              <label for="email" class="block font-sans text-xs uppercase tracking-wider text-brand-dark font-semibold">Correo Electrónico</label>
              <input 
                type="email" 
                id="email" 
                required 
                placeholder="Ej. sofia@gmail.com" 
                class="w-full px-4 py-3 bg-brand-bg border border-brand-sage/15 rounded-lg font-sans text-sm text-brand-dark placeholder-brand-dark-soft/40 focus:outline-none focus:border-brand-sage transition-colors duration-300"
              />
            </div>
            
            <!-- Treatment Selector -->
            <div class="space-y-2">
              <label for="treatment" class="block font-sans text-xs uppercase tracking-wider text-brand-dark font-semibold">Tratamiento de Interés</label>
              <select 
                id="treatment" 
                required
                class="w-full px-4 py-3 bg-brand-bg border border-brand-sage/15 rounded-lg font-sans text-sm text-brand-dark focus:outline-none focus:border-brand-sage transition-colors duration-300 appearance-none"
              >
                <option value="" disabled selected>Seleccioná una opción</option>
                <option value="botox">Baby Botox</option>
                <option value="hialuronico">Ácido Hialurónico Labios/Rostro</option>
                <option value="peeling">Peeling Químico Regenerativo</option>
                <option value="higiene">Higiene Facial Premium Aura</option>
                <option value="velashape">Modelado Corporal con Velashape</option>
                <option value="drenaje">Drenaje Linfático Manual</option>
                <option value="diagnostico">Sólo Consulta de Diagnóstico</option>
              </select>
            </div>
          </div>

          <!-- Message Box -->
          <div class="space-y-2">
            <label for="message" class="block font-sans text-xs uppercase tracking-wider text-brand-dark font-semibold">Comentarios Adicionales (Opcional)</label>
            <textarea 
              id="message" 
              rows="3" 
              placeholder="Contanos tus objetivos estéticos o dudas." 
              class="w-full px-4 py-3 bg-brand-bg border border-brand-sage/15 rounded-lg font-sans text-sm text-brand-dark placeholder-brand-dark-soft/40 focus:outline-none focus:border-brand-sage transition-colors duration-300 resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="w-full inline-flex items-center justify-center px-8 py-4 bg-brand-sage hover:bg-brand-sage-dark text-brand-bg font-display text-xs tracking-widest uppercase font-medium rounded-sm transition-all duration-300 shadow-md hover:shadow-lg cursor-pointer"
          >
            Confirmar Reserva
          </button>
        </form>
      </div>

      <!-- Address & Map Details (Right Column, col-span-5) -->
      <div class="lg:col-span-5 flex flex-col space-y-8 lg:pl-6">
        <div class="space-y-4">
          <span class="font-sans text-xs tracking-[0.2em] uppercase font-semibold text-brand-sage-dark">Ubicación y Horarios</span>
          <h2 class="font-display text-2xl md:text-3xl font-light tracking-tight text-brand-dark">
            Vení a conocernos a <span class="font-medium italic text-brand-sage-dark">nuestra clínica</span>
          </h2>
        </div>

        <!-- Contact details -->
        <div class="space-y-6">
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-brand-sage/10 border border-brand-sage/20 flex items-center justify-center text-brand-sage-dark flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div class="space-y-1">
              <h3 class="font-display text-sm font-semibold text-brand-dark">Dirección</h3>
              <p class="font-sans text-xs text-brand-dark-soft/90">Av. del Libertador 1500, Recoleta, CABA, Argentina</p>
            </div>
          </div>

          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-brand-sage/10 border border-brand-sage/20 flex items-center justify-center text-brand-sage-dark flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.387a12.035 12.035 0 0 1-7.108-7.108c-.115-.44.05-.927.438-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <div class="space-y-1">
              <h3 class="font-display text-sm font-semibold text-brand-dark">Teléfono / Celular</h3>
              <p class="font-sans text-xs text-brand-dark-soft/90">+54 9 11 1234 5678</p>
            </div>
          </div>

          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 rounded-full bg-brand-sage/10 border border-brand-sage/20 flex items-center justify-center text-brand-sage-dark flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <div class="space-y-1">
              <h3 class="font-display text-sm font-semibold text-brand-dark">Horarios de Atención</h3>
              <p class="font-sans text-xs text-brand-dark-soft/90">Lunes a Viernes: 09:00 - 20:00 • Sábados: 09:00 - 14:00</p>
            </div>
          </div>
        </div>

        <!-- Luxury Vector Map (SVG Map representational layout) -->
        <div class="relative w-full aspect-[4/3] rounded-3xl overflow-hidden bg-brand-sage-light/40 border border-brand-sage/15 p-4 flex flex-col items-center justify-center shadow-inner">
          <svg class="w-full h-full text-brand-sage/35" viewBox="0 0 400 300" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Decorative abstract grid representing streets -->
            <path d="M 50 0 L 50 300 M 150 0 L 150 300 M 250 0 L 250 300 M 350 0 L 350 300" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" />
            <path d="M 0 60 L 400 60 M 0 140 L 400 140 M 0 220 L 400 220" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4" />
            
            <!-- Recoleta Parks representation -->
            <path d="M 60 70 Q 100 100 140 70 T 220 70" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
            <circle cx="100" cy="110" r="35" fill="currentColor" class="opacity-15" />
            <circle cx="310" cy="190" r="45" fill="currentColor" class="opacity-15" />
            
            <!-- Path marking a premium route -->
            <path d="M 150 220 L 250 220 L 250 140 L 350 140" stroke="#FAF9F6" stroke-width="8" stroke-linecap="round" />
            <path d="M 150 220 L 250 220 L 250 140 L 350 140" stroke="#8DA399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
            
            <!-- Aura Central Clinic Pin marker -->
            <g transform="translate(250, 140)" class="animate-bounce" style="animation-duration: 2s;">
              <!-- Outer glowing circle -->
              <circle cx="0" cy="0" r="14" fill="#D9C3B0" class="opacity-40 animate-ping" />
              <!-- Inner marker shell -->
              <path d="M0 -15 C-8 -15 -8 -3 0 5 C8 -3 8 -15 0 -15 Z" fill="#3F5249" />
              <circle cx="0" cy="-7" r="3" fill="#FAF9F6" />
            </g>

            <!-- Text elements on the vector map -->
            <text x="265" y="130" fill="#1C2421" font-family="Outfit" font-size="12" font-weight="600" letter-spacing="1">AURA CLINIC</text>
            <text x="70" y="105" fill="#3F5249" font-family="Inter" font-size="9" class="opacity-70">Plaza Francia</text>
            <text x="280" y="225" fill="#3F5249" font-family="Inter" font-size="9" class="opacity-70">Av. del Libertador</text>
          </svg>

          <!-- Small map overlay tooltip -->
          <div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur-sm px-4 py-2 rounded-xl text-[11px] text-brand-dark-soft border border-brand-sage/10 shadow-sm flex items-center justify-between">
            <span>Valet Parking disponible para pacientes</span>
            <span class="font-semibold text-brand-sage-dark">Sin cargo</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const successOverlay = document.getElementById('booking-success');
  const resetBtn = document.getElementById('reset-form');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // Simulate API request and activate elegant success block
    setTimeout(() => {
      successOverlay?.classList.remove('hidden');
      form.reset();
    }, 450);
  });

  resetBtn?.addEventListener('click', () => {
    successOverlay?.classList.add('hidden');
  });
</script>
