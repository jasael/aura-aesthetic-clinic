---
---

<section class="relative py-20 md:py-28 bg-brand-bg overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Main luxury banner container -->
    <div class="relative rounded-[3rem] bg-brand-sage-dark text-white p-8 md:p-16 lg:p-20 overflow-hidden shadow-2xl border border-white/5">
      
      <!-- Background Abstract Shapes & Leaves in white/gold tint -->
      <div class="absolute inset-0 pointer-events-none overflow-hidden opacity-10">
        <div class="absolute -top-[10%] -left-[10%] w-[50%] h-[70%] bg-brand-champagne clip-leaf-right blur-xl"></div>
        <div class="absolute -bottom-[10%] -right-[10%] w-[50%] h-[70%] bg-white clip-leaf-left blur-2xl"></div>
      </div>

      <div class="relative z-10 max-w-3xl mx-auto text-center space-y-8 animate-fade-up">
        <!-- Accent Line -->
        <div class="w-12 h-[1px] bg-brand-champagne mx-auto"></div>

        <!-- Heading layout -->
        <div class="space-y-4">
          <span class="font-sans text-xs tracking-[0.2em] uppercase font-semibold text-brand-champagne">Consulta de Diagnóstico</span>
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-light tracking-tight leading-[1.15]">
            Comenzá hoy tu camino hacia una belleza <span class="font-normal italic text-brand-champagne">radiante y natural</span>
          </h2>
        </div>

        <!-- Descriptive Copy -->
        <p class="font-sans text-sm md:text-base text-brand-sage-light/80 font-light leading-relaxed max-w-xl mx-auto">
          Te invitamos a una sesión de diagnóstico personalizado sin cargo. Nuestros profesionales médicos evaluarán tu fisonomía para recomendarte los tratamientos ideales.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <!-- Primary CTA Button -->
          <a href="#contacto" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 bg-brand-champagne hover:bg-brand-champagne-light text-brand-dark font-display text-xs tracking-widest uppercase font-medium rounded-sm transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 group">
            Reservar Turno On-line
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
          
          <!-- Secondary CTA WhatsApp Button -->
          <a href="https://wa.me/5491112345678?text=Hola,%20quiero%20agendar%20una%20consulta%20de%20diagnóstico%20en%20Aura" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-4 bg-transparent border border-white/20 hover:border-white text-white font-display text-xs tracking-widest uppercase font-medium rounded-sm transition-all duration-300 backdrop-blur-sm hover:bg-white/5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 mr-2">
              <path d="M12.004 2c-5.51 0-9.993 4.483-9.993 9.993 0 1.763.457 3.483 1.326 5l-1.411 5.154 5.273-1.383c1.464.8 3.102 1.222 4.805 1.222 5.51 0 9.993-4.483 9.993-9.993C21.997 6.483 17.514 2 12.004 2zm5.347 14.004c-.22.614-1.282 1.134-1.763 1.182-.44.045-.87.23-2.822-.53-2.495-.97-4.088-3.507-4.21-3.667-.11-.16-.92-1.222-.92-2.332 0-1.11.58-1.65.79-1.87.21-.22.46-.27.61-.27.15 0 .3.01.43.01.14 0 .32-.05.5.38.19.45.65 1.58.71 1.7.06.12.1.26.02.42-.08.16-.12.26-.24.4-.12.14-.26.31-.37.42-.12.12-.25.25-.11.49.14.24.62 1.02 1.33 1.65.91.81 1.68 1.06 1.92 1.18.24.12.38.1.52-.06.14-.16.61-.71.77-.95.16-.24.32-.2.54-.12.22.08 1.41.66 1.65.78.24.12.4.18.46.28.06.1.06.58-.16 1.19z"/>
            </svg>
            Agendar por WhatsApp
          </a>
        </div>

        <!-- Subtle security label -->
        <span class="block font-sans text-[10px] uppercase tracking-widest text-brand-sage-light/45">
          Atención personalizada • Cupos de diagnóstico limitados
        </span>
      </div>

    </div>
  </div>
</section>
